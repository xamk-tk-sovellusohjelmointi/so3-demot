// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}


model Kuva {
  id Int @id @default(autoincrement())
  teksti String
  tiedosto String
  aika DateTime @default(now())
}